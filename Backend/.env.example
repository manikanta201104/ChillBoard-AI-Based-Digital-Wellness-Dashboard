# Core
PORT=5000
MONGO_URI=mongodb://localhost:27017/chillboard
JWT_SECRET=replace_with_strong_secret

# Admin (optional)
# bcrypt hash of the admin password. Generate with: node Backend/bcrypt-test.js
# ADMIN_PASSWORD_HASH=$2b$10$exampleexampleexampleexampleexampleexampleexamplex

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="ChillBoard <no-reply@yourdomain.com>"
