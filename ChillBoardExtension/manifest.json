{
  "manifest_version": 3,
  "name": "ChillBoard Extension",
  "version": "1.0",
  "description": "Tracks screen time for ChillBoard wellness dashboard",
  "permissions": ["tabs", "windows", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
  "default_popup": "popup.html"
}
}