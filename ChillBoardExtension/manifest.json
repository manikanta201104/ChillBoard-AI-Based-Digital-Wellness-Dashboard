{
  "manifest_version": 3,
  "name": "ChillBoard Extension",
  "version": "1.0",
  "description": "Tracks screen time for ChillBoard wellness dashboard",
  "permissions": [
    "storage",
    "tabs",
    "windows",
    "notifications",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "background.js"],
      "matches": ["<all_urls>"]
    }
  ]
}